{
  "version": 1,
  "variables": {
    "DATABASE_URL": "postgresql://${{Postgres.PGUSER}}:${{Postgres.PGPASSWORD}}@${{Postgres.PGHOST}}:${{Postgres.PGPORT}}/${{Postgres.PGDATABASE}}",
    "ENVIRONMENT": "production"
  },
  "services": {
    "api": {
      "source": ".",
      "buildCommand": "cd frontend && npm install && npm run build && cd ../backend && pip install -r requirements.txt && python -m playwright install chromium",
      "startCommand": "cd backend && uvicorn main:app --host 0.0.0.0 --port 8000",
      "port": 8000
    },
    "postgres": {
      "type": "postgres"
    }
  }
}
